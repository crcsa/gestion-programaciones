# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Drizzle ORM)
# IMPORTANTE: usar el SESSION pooler (puerto 5432 del host *.pooler.supabase.com),
# NO el transaction pooler (puerto 6543). El app corre como server persistente y
# dispara queries concurrentes; postgres-js contra el transaction pooler de
# Supavisor desincroniza el protocolo bajo concurrencia y una query queda colgada
# para siempre (state=active/ClientRead). El session pooler asigna un backend
# dedicado por conexión y no tiene esa carrera.
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-REGION.pooler.supabase.com:5432/postgres

# Cron jobs (Authorization: Bearer ${CRON_SECRET}). Vercel Cron lo inyecta auto en producción.
CRON_SECRET=replace-with-random-32+-char-secret
